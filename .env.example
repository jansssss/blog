# Supabase Configuration
# Supabase 대시보드 > Settings > API에서 확인 가능

# Project URL (https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Anon/Public Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key (서버 사이드 전용, 공개하지 마세요!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron Secret (임의의 랜덤 문자열)
# 예: openssl rand -base64 32
CRON_SECRET=your-random-secret-key

# OpenAI API Key - 이미지 생성 전용 (DALL-E 3)
# 기존 OPENAI_API_KEY와 별도 관리 (Vercel 환경변수 충돌 방지)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_IMG_KEY=your-openai-api-key-for-images
