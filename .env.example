# Supabase Configuration
# Supabase 대시보드 > Settings > API에서 확인 가능

# Project URL (https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Anon/Public Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key (서버 사이드 전용, 공개하지 마세요!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron Secret (임의의 랜덤 문자열)
# 예: openssl rand -base64 32
CRON_SECRET=your-random-secret-key

# 금융감독원 「금융상품 통합 비교공시」 OpenAPI 인증키
# 은행별 금리 비교(/compare/bank-rates) 데이터 수집에 사용
# 발급: https://finlife.fss.or.kr → 오픈API → 인증키 신청 (무료, 이메일 인증)
#
# 이 키는 GitHub Actions 수집 잡에서만 쓰인다. Vercel 에는 등록할 필요가 없다.
# (사이트는 저장소에 커밋된 data/finlife-offers.json 만 읽는다)
# → GitHub: Settings > Secrets and variables > Actions > FSS_FINLIFE_API_KEY
FSS_FINLIFE_API_KEY=your-fss-finlife-api-key

# OpenAI API Key - 이미지 생성 전용 (DALL-E 3)
# 기존 OPENAI_API_KEY와 별도 관리 (Vercel 환경변수 충돌 방지)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_IMG_KEY=your-openai-api-key-for-images

# Google AdSense 수동 광고 단위 (선택)
# AdSense 콘솔 > 광고 > 광고 단위별 에서 생성 후 data-ad-slot 숫자값을 입력
# 미설정 시 본문 수동 광고는 렌더링되지 않음(자동광고만 동작) → 빈 광고 박스 없음
# 게시자 ID는 기본값(ca-pub-6676446565175753) 사용, 변경 시 NEXT_PUBLIC_ADSENSE_CLIENT 설정
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-6676446565175753
# 본문 중간 인아티클 광고 단위 ID (광고 유형: 인피드/인아티클 권장)
NEXT_PUBLIC_ADSENSE_SLOT_INARTICLE=
# 본문 하단 멀티플렉스 광고 단위 ID (광고 유형: 멀티플렉스)
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=
# 계산기 페이지 하단 광고 단위 ID (광고 유형: 디스플레이/반응형)
NEXT_PUBLIC_ADSENSE_SLOT_CALCULATOR=
